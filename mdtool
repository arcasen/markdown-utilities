#!/usr/bin/env python3

"""Markdown Tool
"""

import argparse
import re
import sys
import shutil
import os
from collections import OrderedDict  # 用于保持插入顺序
import panflute as pf
from pathlib import Path
from functools import reduce

# 嵌套 Markdown 语法: 行首可选空格 + ![[ + 文件路径 + (: 范围) ]] + 可选空格 + 行尾
nested_markdown_pattern = re.compile(
    r'^(\s*)!\[\[\s*(?P<filepath>[^:\]]+?)\s*(?::\s*(?P<range>\d+(?:-\d*)?)\s*)?\]\]\s*$',
    re.MULTILINE
)

# 标准 Inline 图片语法: ![alt] + ( + url + 可选标题 + )
# ![<alt-text>](<url> "<picture-title>")
# 在标准的 Markdown 规范（CommonMark）中，图片的 title（以及超链接的 title）确实有且只有三种合法的闭合形式：
# 双引号("title") —— 最常用
# 单引号('title')
# 小括号((title))
inline_image_pattern = re.compile(
    r'\!\[(?P<alt>(?:\\[\[\]]|[^\[\]])*)\]'             # 允许 alt 中出现转义的中括号
    r'\(\s*'
    r'(?P<url>[^\s\)]+)'                                # URL 不能包含空格和右括号
    r'(?:\s+(?P<title>"[^"]*"|\'[^\']*\'|\([^)]*\)))?'  # 严格成对的引号/括号
    r'\s*\)',
    re.MULTILINE
)

# 标准 Reference 图片定义: [ref_id]: + url(必须以指定图片格式结尾) + 可选标题
# ![ < atl-text > ][ < picture-reference > ]
# [<pciture-reference>]: <url> "<picture-title>"
reference_image_pattern = re.compile(
    r'\[(?P<ref>[^\]]+)\]\:\s*'                          # 匹配参考标识，如 [ref]:
    # URL
    r'(?P<url>\S+?\.(?:png|jpg|jpeg|gif|webp|svg))'      # 限定图片后缀（不分大小写）
    r'(?:\s+(?P<title>"[^"]*"|\'[^\']*\'|\([^)]*\)))?',  # 严格成对的 title 形式
    re.MULTILINE | re.IGNORECASE                         # 允许匹配大写后缀, 如 .PNG
)


def parse_range(range_str):
    """解析行号范围字符串，返回基于 0 的 (start, end) 索引切片。

    支持格式:
    - None    -> 引入全量文件 (0, None)
    - "10"    -> 仅第 10 行
    - "10-20" -> 第 10 行到第 20 行 (闭区间)
    - "10-"   -> 从第 10 行直到文件末尾
    """
    if not range_str:
        return 0, None  # 从首行到文件末尾

    if '-' in range_str:
        start_part, end_part = range_str.split('-', 1)
        start = int(start_part) - 1 if start_part else 0
        end = int(end_part) if end_part else None  # None 表示到末尾
        return start, end
    else:
        # 单行情况
        start = int(range_str) - 1
        return start, start + 1


def process_expansion(filepath):
    """Processing file expansion.

    Args:
        filepath: str, Markdown document file path

    Returns:
        (stdout): processed document text
    """

    with open(filepath, 'r', encoding='utf-8') as f:
        for line in f:
            match = nested_markdown_pattern.match(line)

            if match:
                indent_before = match.group(1)
                subdoc_path = match.group('filepath').strip()
                range_str = match.group('range')

                start, end = parse_range(range_str)

                # 注意: open 函数不能打开含 ~ 的路径
                safe_path = os.path.expanduser(subdoc_path)

                with open(safe_path, 'r', encoding='utf-8') as subdoc:
                    sub_lines = subdoc.readlines()

                    # 确定切片的终止边界
                    slice_end = end if end is not None else len(sub_lines)
                    target_lines = sub_lines[start:slice_end]

                    for include_line in target_lines:
                        print(f"{indent_before}{include_line}", end="")

                print("")  # 输出空行
            else:
                print(line, end="")


def process_markdown_depends(dir):
    """Generating dependency rules.

    Args:
        dir: str, directory including markdown files(.markdown)

    Returns:
        (stdout): the dependencies in the form of 'target: dependencies'  
    """

    print("# Nested markdowns")

    for root, _, files in os.walk(dir):
        for file in files:
            if not file.endswith('.markdown'):
                continue

            filepath = os.path.join(root, file)

            # 计算相对路径并转换为目标文件名：xxx.md
            rel_path = os.path.normpath(os.path.relpath(filepath, dir))
            target = rel_path[:-9] + '.md'  # 去除 .markdown，添加 .md

            # 收集唯一嵌入文件（保持第一次出现的顺序）
            depends = OrderedDict()

            with open(filepath, 'r', encoding='utf-8') as f:
                for line in f:
                    match = nested_markdown_pattern.match(line)
                    if match:
                        subdoc_path = match.group(
                            'filepath').strip()  # 去除内容内首尾空格
                        if subdoc_path and subdoc_path not in depends:
                            subdoc_path_norm = os.path.normpath(subdoc_path)
                            depends[subdoc_path_norm] = None

            if depends:
                print(f"{target}: {' '.join(depends.keys())}")


def process_image_depends(dir):
    """Generating image dependency rules.

    Args:
        dir: str, directory including markdown files(.markdown)

    Returns:
        (stdout): the dependencies in the form of 'target: dependencies'  
    """

    print("# Nested images")

    # 排除网络图片（即 URL 形式的图片），只提取 本地文件路径的图片文件名，
    # 你可以在判断 Image 元素的 url 时，先检测它是否为 本地路径
    # （而非以 http: //、https: // 等开头的网络链接）
    URL_PATTERN = re.compile(r'^https?://|^//', re.IGNORECASE)

    # 查找所有图片元素
    def action(elem, doc):
        if isinstance(elem, pf.Image):
            # 判断是否为本地路径（非网络 URL）
            if (not URL_PATTERN.match(elem.url)):
                # 注意：这里需要一种方式把数据传出去
                url_norm = os.path.normpath(elem.url)
                doc.depends[url_norm] = None

    for root, _, files in os.walk(dir):
        for file in files:
            if not file.endswith('.markdown'):
                continue

            filepath = os.path.join(root, file)

            # 计算相对路径并转换为目标文件名：xxx.md
            rel_path = os.path.normpath(os.path.relpath(filepath, dir))
            target = rel_path[:-9] + '.md'  # 去除 .markdown，添加 .md

            # 直接读取文件并转换为 panflute 能够处理的 doc 对象
            with open(filepath, 'r', encoding='utf-8') as f:
                content = f.read()

                # 将 markdown 文本转换为抽象语法树 (AST)
                doc = pf.convert_text(
                    content, input_format='markdown', standalone=True)

                # 传递路径给 action
                doc.filepath = filepath

                # 给 doc 对象临时挂载一个属性来存储结果
                # 收集唯一嵌入文件（保持第一次出现的顺序）
                doc.depends = OrderedDict()

                # 对文档应用 action
                doc.walk(action)

                if doc.depends:
                    print(f"{target}: {' '.join(doc.depends.keys())}")


def process_depends(dir):
    """Generating nested markdown and image dependency rules.

    Args:
        dir: str, directory including markdown files(.markdown)

    Returns:
        (stdout): the dependencies in the form of 'target: dependencies'  
    """

    process_markdown_depends(dir)
    process_image_depends(dir)


def process_init(target_dir, article=False, overwrite=False):
    """Creating a project from a template/boilerplate.

    Args:
        target_dir: str, directory name
        article: bool, create an article if true, else book
        overwrite: bool, overwrite while file existing

    Returns:
        None
    """

    if article:
        source_dir = os.path.expanduser(
            '~/.local/share/pandoc/boilerplate/article')
    else:
        source_dir = os.path.expanduser(
            '~/.local/share/pandoc/boilerplate/book')

    if not os.path.isdir(source_dir):
        print(
            f"Error: The source directory does not exist or is not a directory: {source_dir}.")
        return

    if not os.path.exists(target_dir):
        os.makedirs(target_dir)

    for root, dirs, files in os.walk(source_dir):
        # 计算相对路径
        rel_path = os.path.relpath(root, source_dir)
        dst_path = target_dir if rel_path == '.' else os.path.join(
            target_dir, rel_path)

        # 构建目标子目录(如果不存在)
        os.makedirs(dst_path, exist_ok=True)

        # 复制文件
        for file in files:
            src_file = os.path.join(root, file)
            dst_file = os.path.join(dst_path, file)

            if os.path.exists(dst_file) and not overwrite:
                # 文件已存在，询问是否覆盖
                response = input(
                    f"The file already exists: {dst_file}.\nDo you want to overwrite it? (y/N): ").strip().lower()
                if response != 'y':
                    print(f"Skipped: {dst_file}")
                    continue

            # 执行拷贝（保留元数据）
            shutil.copy2(src_file, dst_file)
            print(f"Copied: {src_file} -> {dst_file}")


# 通过 Panflute 修改 pf.Image 元素的 url 后, AST（抽象语法树）在存储和导出
# Markdown 时会将 ![[改写成 \!\[\[, 我们需要看一看 Markdown 的底层解析逻辑
# 和 AST 的工作原理. 这是因为 ![[ 触犯了标准 Markdown 解析器的"语法安全防御机制".
def rebase_path(filepath, dist_dir="."):
    """Rebasing path of nested images and markdowns

    Args:
        filepath: str, Markdown document file path
        dist_dir: str, new base directory name

    Returns:
        (stdout): processed document text
    """

    filepath = Path(filepath).expanduser().resolve()
    dist_dir = Path(dist_dir).expanduser().resolve()

    # 计算相对路径 (安全处理：先转绝对路径，避免 .. 或重复斜杠导致计算失败)
    try:
        file_dir = filepath.parent
        rel_path = file_dir.relative_to(dist_dir)
        rel_path_str = f"{rel_path}/" if str(rel_path) != "." else ""
    except ValueError:
        print(
            f"Warning: '{filepath}' is NOT inside the directory '{dist_dir}'. Skip!")
        return

    with open(filepath, "r", encoding="utf-8") as f:
        content = f.read()

    # 匹配与替换逻辑
    def rebase_nested_markdown(match):
        # 提取前导空格（原正则的第一组）
        indent_before = match.group(1) or ""

        # 使用命名捕获组提取文件路径
        img_path = match.group("filepath").strip()

        # 如果是绝对路径或家目录开头，保持原样不替换
        if Path(img_path).expanduser().is_absolute():
            return match.group(0)

        # 提取命名捕获组中的范围（如果存在的话，形如 ':10-20' 或 ':10'）
        # 注意：原正则中包含了前面的冒号，所以我们需要提取完整的匹配文字
        # 原正则末尾的 \s*$ 匹配了尾随空格，这里我们也需要保留
        range_part = ""
        # 检查整个可选的冒号+范围组是否匹配到了
        # 因为整个可选组没有命名，它是第 3 个匿名组 (::\s*(?P<range>...)\s*)?
        if match.group(3):
            # 重新组装冒号和范围，或者直接用 match.group(3) 的原始文本
            range_part = f":{match.group(3)}"

        # 拼接新的相对路径
        new_img_path = f"{rel_path_str}{img_path}"

        # 组装最终结果：前导空格 + ![[ + 新路径 + 范围(若有) + ]] + 尾随（通过原正则末尾的 \s*$ 处理）
        # 注意：由于原正则末尾是 \s*$，整个匹配项会吞掉行尾的空格，所以在这里不需要额外加 \n
        return f"{indent_before}![[{new_img_path}{range_part}]]"

    def rebase_inline_image(match):
        img_alt = match.group("alt")
        img_url = match.group("url")
        img_title = match.group("title") or ""

        if img_url.startswith(('http://', 'https://', 'ftp://', '/', '~')):
            return match.group(0)  # 返回匹配到的整行，保持原样

        # 返回拼接新的相对路径
        return f"![{img_alt}]({rel_path_str}{img_url} {img_title})"

    def rebase_reference_image(match):
        img_ref = match.group("ref")
        img_url = match.group("url")
        img_title = match.group("title") or ""

        if img_url.startswith(('http://', 'https://', 'ftp://', '/', '~')):
            return match.group(0)  # 返回匹配到的整行，保持原样

        # 返回拼接新的相对路径
        return f"[{img_ref}]:{rel_path_str}{img_url} {img_title}"

    # 类似于链式调用
    rules = [
        (nested_markdown_pattern, rebase_nested_markdown),
        (inline_image_pattern, rebase_inline_image),
        (reference_image_pattern, rebase_reference_image),
    ]

    updated_content = reduce(
        lambda t, rule: rule[0].sub(rule[1], t), rules, content)

    # 写回文件
    with open(filepath, "w", encoding="utf-8") as f:
        f.write(updated_content)


if __name__ == "__main__":
    try:
        parser = argparse.ArgumentParser(
            prog="mdtool",
            description="Markdown Processing Tool",
            formatter_class=argparse.RawDescriptionHelpFormatter,
            epilog="""
example:
  mdtool init [target_dir]  # default dir: .
  mdtool init [target_dir] -y  # overwrite
  mdtool init [target_dir] -a  # create an article
  mdtool depend input.md 
  mdtool expand input.md
  mdtool rebase input.md -d dir # rebase paths of nested images and markdowns
"""
        )

        # 添加版本参数
        # %(prog)s 是一个占位符，会自动替换为你的文件名
        parser.add_argument(
            '-v', '--version',
            action='version',
            version='%(prog)s 0.4.0'
        )

        subparsers = parser.add_subparsers(
            # title="note",
            # description="subcommands implement different functions",
            dest="command",  # 存储子命令名称的属性名
            help="Description",  # 附加帮助信息
            metavar="Command",  # 帮助信息中的占位符
            required=True,  # 是否必须提供子命令 (Python 3.7+)
        )

        # ------------------- init (-i) -------------------
        p_i = subparsers.add_parser(
            "init",
            aliases=["i"],
            help="create a project from a boilerplate"
        )
        p_i.add_argument("dir", nargs="?", default=".",
                         help="destination directory(default: '.')")
        p_i.add_argument('-a', '--article', action='store_true',
                         help='Overwrite')  # default: False
        p_i.add_argument('-y', '--yes', action='store_true',
                         help='Overwrite')  # default: False

        p_i.set_defaults(func=lambda args: process_init(
            args.dir, article=args.article, overwrite=args.yes))

        # ------------------- depend (-d) -------------------
        p_d = subparsers.add_parser(
            "depend",
            aliases=["d"],
            help="generate nested markdown and image dependencies rules"
        )
        p_d.add_argument("dir", nargs="?", default=".",
                         help="directory of .markdown files(default: '.')")

        p_d.set_defaults(func=lambda args: process_depends(args.dir))

        # ------------------- expand (-e) -------------------
        p_e = subparsers.add_parser(
            "expand",
            aliases=["e"],
            help="process markdown expansion"
        )
        p_e.add_argument("file", help=".markdown file to be processed")

        p_e.set_defaults(func=lambda args: process_expansion(args.file))

        # ------------------- init (-i) -------------------
        p_r = subparsers.add_parser(
            "rebase",
            aliases=["r"],
            help="rebase paths of nested images and markdowns"
        )

        p_r.add_argument("file", help=".markdown file to be processed")
        p_r.add_argument('-d', '--dist',
                         type=Path,
                         default=Path('.'),  # 默认是当前目录
                         help="dist directory"
                         )

        p_r.set_defaults(func=lambda args: rebase_path(args.file, args.dist))

        # 解析并执行
        args = parser.parse_args()
        args.func(args)

    except Exception as e:
        print(e, file=sys.stderr)
